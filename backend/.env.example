# Banco de dados
DB_HOST=localhost
DB_PORT=5433
DB_DATABASE=qa_control
DB_USER=qa_user
DB_PASSWORD=qa_password

# JWT — gerado com: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=GERE_UM_VALOR_AQUI
JWT_EXPIRES_IN=8h

# Token para cadastro de novos usuários — compartilhe apenas com quem precisa criar conta
REGISTER_TOKEN=GERE_UM_VALOR_AQUI

# Bcrypt rounds (opcional — padrão: 12)
# BCRYPT_ROUNDS=12
