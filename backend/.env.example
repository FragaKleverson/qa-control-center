# Banco de dados — Prisma (necessário para migrations)
DATABASE_URL=postgresql://qauser:qapass@localhost:5433/qadb

# pg pool (mantido para compatibilidade com as queries existentes)
DB_HOST=localhost
DB_PORT=5433
DB_DATABASE=qadb
DB_USER=qauser
DB_PASSWORD=qapass

# JWT — gerado com: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=GERE_UM_VALOR_AQUI
JWT_EXPIRES_IN=8h

# Token para cadastro de novos usuários — compartilhe apenas com quem precisa criar conta
REGISTER_TOKEN=GERE_UM_VALOR_AQUI

# Bcrypt rounds (opcional — padrão: 12)
# BCRYPT_ROUNDS=12

# ── Rate Limiting — configurações opcionais ────────────────────────────────────
# Global (todas as rotas): janela em ms e máx. req por IP
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=200

# Auth/Login (brute-force): janela em ms e máx. tentativas FALHAS por IP
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=10

# Register: janela em ms e máx. cadastros por IP
# RATE_LIMIT_REGISTER_WINDOW_MS=3600000
# RATE_LIMIT_REGISTER_MAX=5

# Per-user (rotas autenticadas): janela em ms e máx. req por user ID
# RATE_LIMIT_USER_WINDOW_MS=900000
# RATE_LIMIT_USER_MAX=300

# Password reset: janela em ms e máx. solicitações por IP
# RATE_LIMIT_PWD_RESET_WINDOW_MS=900000
# RATE_LIMIT_PWD_RESET_MAX=3

# ── Password Reset ─────────────────────────────────────────────────────────────
# Tempo de validade do token de reset de senha em ms (padrão: 3600000 = 1 hora)
# PASSWORD_RESET_EXPIRES_MS=3600000
