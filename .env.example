# ==============================================
# QA Control Center - Environment Variables
# ==============================================
# Copie este arquivo para .env e preencha os valores
# NUNCA comite o .env com credenciais reais

# --- PostgreSQL ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- Backend (conexão com o banco) ---
DB_HOST=db
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_DATABASE=

# --- Portas expostas ---
BACKEND_PORT=3001
FRONTEND_PORT=5173
DB_PORT_EXPOSED=5432
