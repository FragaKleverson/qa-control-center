# ==============================================
# QA Control Center - Environment Variables
# ==============================================
# Copie este arquivo para .env e preencha os valores
# NUNCA comite o .env com credenciais reais

# --- Ambiente ---
# "production" ativa logs de auditoria, oculta mensagens de erro internas
# "development" ativa logs coloridos e expõe mensagens de erro no JSON
NODE_ENV=development

# --- PostgreSQL ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# --- Backend (conexão com o banco) ---
DB_HOST=db
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_DATABASE=

# --- Portas expostas ---
BACKEND_PORT=3001
FRONTEND_PORT=5173
# ATENÇÃO: Em produção, remova ou não defina DB_PORT_EXPOSED para não expor o banco.
DB_PORT_EXPOSED=

# --- Segurança: CORS ---
# Origens de browser permitidas, separadas por vírgula.
# Inclua APENAS a URL real do frontend em produção.
# Ex: https://qa.suaempresa.com,https://qa-staging.suaempresa.com
ALLOWED_ORIGINS=http://localhost:5173

# --- Segurança: Rate Limiting ---
# RATE_LIMIT_WINDOW_MS: janela de tempo em milissegundos (padrão: 900000 = 15 min)
# RATE_LIMIT_MAX: máximo de requisições por IP na janela (padrão: 200)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
